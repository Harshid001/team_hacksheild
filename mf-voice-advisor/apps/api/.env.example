# MF Voice Advisor API — Environment Variables
# Copy this to .env and adjust values as needed.

PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/mf_voice_advisor

# Ollama config — NEVER hardcode the model name in source code
# Change OLLAMA_MODEL if qwen3:4b is too slow on your machine
OLLAMA_MODEL=qwen3:4b
OLLAMA_BASE_URL=http://localhost:11434

# Python Analytics Service
ANALYTICS_SERVICE_URL=http://localhost:8005
